# ==========================================
# DJANGO SECRET KEY
# ==========================================
# Generate a secure random key. In production, use a unique value.
# You can generate one with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here-change-this-in-production

# ==========================================
# DEBUG MODE
# ==========================================
# Set to False in production
DEBUG=False

# ==========================================
# ALLOWED HOSTS
# ==========================================
# Comma-separated list of domain names your site runs on
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com,www.your-domain.com

# ==========================================
# EMAIL CONFIGURATION
# ==========================================
# For Gmail, use an App Password (not your regular password)
# Generate one at: https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password-here
DEFAULT_FROM_EMAIL=your-email@gmail.com

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://username:password@host:port/database

# ==========================================
# DATABASE OPTIONS
# ==========================================
DATABASE_CONN_MAX_AGE=600
DATABASE_SSL_REQUIRE=True
DATABASE_DISABLE_SERVER_SIDE_CURSORS=True